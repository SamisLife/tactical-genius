# Google AI API Key https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Football Data API Key https://www.football-data.org/client/register
# Free tier: 10 req/min, access to top leagues (PL, CL, BL1, SA, PD, FL1, WC, EC)
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# Free tier (requires billing on file): gemini-2.5-flash (10 req/min, 250/day)
# or gemini-2.5-flash-lite (15 req/min, 1,000/day) for lighter usage
GEMINI_MODEL=gemini-2.5-flash

# optional: set to "development" to enable verbose logging
ENV=development
